######################################################################
# Database (Postgres 17)
######################################################################
# When running outside the container, point this at your Postgres instance.
# Inside the AFT container the entrypoint sets DATABASE_URL automatically to
# the local Postgres unix socket.
DATABASE_URL=postgres://aft:aft@127.0.0.1:5432/aft

######################################################################
# Reverse-proxy security
######################################################################
# Long random string. Must match the X-AFT-Proxy-Secret header value
# configured in the in-container nginx (see docker/nginx.conf). Required in
# production; if unset the Bun server runs in dev mode and accepts requests
# from anywhere on 127.0.0.1.
AFT_PROXY_SHARED_SECRET=

# When set to 1, the Secure cookie flag is dropped (for HTTP-only local dev).
# Leave UNSET in production.
AFT_ALLOW_INSECURE_COOKIES=

######################################################################
# Bootstrap admin
######################################################################
# Set BOTH on first boot to seed an initial admin user. The user is created
# with must_change_password=1 so first login forces a password reset. Once
# the admin exists these vars are ignored.
AFT_ADMIN_BOOTSTRAP_EMAIL=admin@aft.gov
AFT_ADMIN_BOOTSTRAP_PASSWORD=

######################################################################
# SMTP / email notifications
######################################################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AFT System <noreply@aft-system.mil>
SMTP_REPLY_TO=aft-support@aft-system.mil

# For Office 365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false

# For local mail server (no auth)
# SMTP_HOST=localhost
# SMTP_PORT=25
# SMTP_SECURE=false

######################################################################
# Postgres credentials (used by docker-compose / entrypoint)
######################################################################
POSTGRES_USER=aft
POSTGRES_PASSWORD=aft
POSTGRES_DB=aft